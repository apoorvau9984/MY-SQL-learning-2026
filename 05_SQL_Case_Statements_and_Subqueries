-- Case statements CASE 1
SELECT first_name,
last_name,
age,
CONCAT( first_name,"  ",last_name) AS full_name,
CASE 
WHEN age>=40  AND age <=60 THEN"MIDDLE"
WHEN age BETWEEN 60 AND 70 then "OLD"
WHEN age<=40 THEN " YOUNG"


END AS cateogry_
FROM parks_and_recreation.employee_demographics;

 -- CASE 2 (BONUS)
 
 SELECT first_name, last_name,salary,
 CONCAT( first_name," " ,last_name) AS FUll_NAME,
 CASE
 WHEN  salary<=50000 THEN salary*1.05
 WHEN  salary>=70000 THEN salary*1.07
 
 END AS new_salary,
 CASE
 WHEN dept_id=6 THEN salary*0.10
 END AS bonus_
 FROM parks_and_recreation.employee_salary;
 
 # subqueries EXAMPLE 1
 SELECT *
 FROM parks_and_recreation.employee_demographics
 WHERE employee_id IN(SELECT employee_id
 FROM employee_salary
 WHERE dept_id=1);
 
 -- EXAMPLE 2
 SELECT first_name,salary,
 (SELECT AVG(salary)
 FROM  parks_and_recreation.employee_salary)AS AVG_salary
 FROM  parks_and_recreation.employee_salary;





 
 
 
