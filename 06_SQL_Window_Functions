-- window function 
# EXAMPLE 1
SELECT first_name,
       salary,
       AVG(salary) OVER() AS avg_salary
FROM  parks_and_recreation.employee_salary;

# EXAMPLE 2 (PARTITION)
SELECT gender , SUM(salary) OVER(partition by gender)
FROM parks_and_recreation.employee_demographics dem
JOIN employee_salary  sal
 ON dem.employee_id= sal.employee_id;
 
 # EXAMPLE 3 (RANK)
 SELECT dem.employee_id,dem.first_name,dem.last_name,gender,age,salary,
RANK() OVER(PARTITION BY gender ORDER BY salary DESC) AS rank_
FROM parks_and_recreation.employee_demographics dem
JOIN parks_and_recreation.employee_salary sal
ON dem.employee_id = sal.employee_id;

# EXAMPLE 4 (ROW_NUMBER)
 SELECT dem.employee_id,dem.first_name,dem.last_name,gender,age,salary,
ROW_NUMBER() OVER(PARTITION BY gender ORDER BY salary DESC) AS row_no
FROM parks_and_recreation.employee_demographics dem
JOIN parks_and_recreation.employee_salary sal
ON dem.employee_id = sal.employee_id;

#  EXAMPLE 5(COMBINE OF ROW AND RANK)
SELECT dem.first_name,
       sal.salary,
       dem.age,
       ROW_NUMBER() OVER(PARTITION BY sal.salary ORDER BY dem.first_name ASC) AS row_no,
       RANK() OVER(PARTITION BY sal.salary ORDER BY dem.first_name ASC) AS rank_no,
       DENSE_RANK() OVER(PARTITION BY sal.salary ORDER BY dem.first_name ASC) AS denserank_no
FROM parks_and_recreation.employee_demographics dem
JOIN parks_and_recreation.employee_salary sal
ON dem.employee_id = sal.employee_id;


 
